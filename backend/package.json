{
    "name":  "snake-backend",
    "version":  "1.0.0",
    "packageManager":  "pnpm@11.0.0",
    "description":  "Snake game backend with persistent leaderboard",
    "main":  "dist/server.js",
    "scripts":  {
                    "start":  "node dist/server.js",
                    "dev":  "tsc -w -p tsconfig.json",
                    "build":  "tsc -p tsconfig.json \u0026\u0026 tsc --noEmit -p ../frontend/tsconfig.json",
                    "typecheck":  "tsc --noEmit -p tsconfig.json \u0026\u0026 tsc --noEmit -p ../frontend/tsconfig.json"
                },
    "dependencies":  {
                         "better-sqlite3":  "^9.4.3",
                         "express":  "^4.18.2",
                         "uuid":  "^9.0.0"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.12",
                            "@types/express":  "^4.17.23",
                            "@types/node":  "^24.0.0",
                            "typescript":  "^5.8.3"
                        }
}
